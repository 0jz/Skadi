<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/widget_city"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Beograd"
        android:textColor="#EFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_temp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="19°  Delimično oblačno"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp" />

    <Space
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_sos"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_danger"
            android:gravity="center"
            android:text="SMS"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_support"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_neutral"
            android:gravity="center"
            android:text="SOS"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
